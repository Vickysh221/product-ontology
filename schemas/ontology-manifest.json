{
  "library_name": "Product Learning Library",
  "core_principle": "event-centered, evidence-constrained, review-updated ontology",
  "entities": [
    "product",
    "event",
    "artifact",
    "source",
    "claim",
    "pattern",
    "thesis",
    "verdict",
    "counterclaim",
    "review",
    "why_now_hypothesis",
    "decision",
    "question",
    "method",
    "session_trace",
    "writeback_proposal"
  ],
  "relations": [
    "Artifact DERIVED_FROM Source",
    "Event HAS_EVIDENCE Artifact",
    "Event UPDATES Product",
    "Claim INTERPRETS Event",
    "Pattern ABSTRACTS_FROM Event | Claim",
    "Counterclaim CONTESTS Claim | Pattern | Thesis",
    "Event TESTS WhyNowHypothesis",
    "Review PRODUCES Verdict",
    "Verdict UPDATES Claim | Pattern | Thesis",
    "Review EVALUATES Claim | Pattern | Thesis",
    "SessionTrace PRODUCES Claim",
    "Method GUIDES ReviewOrResearch",
    "WritebackProposal PATCHES Object"
  ]
}
