{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaimRecord",
  "type": "object",
  "required": [
    "claim_id",
    "claim_text",
    "about_objects",
    "event_refs",
    "artifact_refs",
    "status",
    "confidence"
  ],
  "properties": {
    "claim_id": {"type": "string"},
    "claim_text": {"type": "string"},
    "about_objects": {"type": "array", "items": {"type": "string"}},
    "event_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "artifact_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "counterevidence_refs": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "status": {"type": "string"}
  }
}
